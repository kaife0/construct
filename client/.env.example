# Where the Express backend (../server) runs — used by next.config.ts to
# proxy /api/* requests there server-side (keeps the browser same-origin).
API_URL="http://localhost:4000"

# Must be the EXACT same value as JWT_SECRET in ../server/.env — the Next.js
# edge middleware verifies the admin session JWT's signature here, the
# server signs it there. Generate with: openssl rand -base64 32
JWT_SECRET=""

# Public site URL (used for canonical links)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
