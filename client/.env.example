# MongoDB Atlas connection string (Phase 5+).
# Create a free cluster at https://www.mongodb.com/cloud/atlas, add a DB user,
# allow network access, then paste the "Connect your application" URI here.
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/casastruct?retryWrites=true&w=majority"

# Auth.js secret for admin sessions (Phase 6). Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Public site URL (used for canonical links / auth callbacks)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
