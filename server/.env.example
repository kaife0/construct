PORT=4000

# MongoDB Atlas connection string — same database the admin panel manages.
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/casastruct?retryWrites=true&w=majority"

# Comma-separated list of allowed frontend origins.
CORS_ORIGIN="http://localhost:3000"

# Secret used to sign admin session JWTs. Generate with: openssl rand -base64 32
JWT_SECRET=""

# NODE_ENV=production makes the session cookie Secure (HTTPS-only). Leave unset in dev.
# NODE_ENV="production"

# Image storage backend: "local" (default) saves to ./uploads on disk.
# Switch to "cloudinary" at deploy if the host's disk is ephemeral (Render, Vercel, ...).
STORAGE_DRIVER="local"
# Override where local images are written (default: server/uploads). Only used when STORAGE_DRIVER=local.
# UPLOADS_DIR="/var/www/casastruct/uploads"

# Required only when STORAGE_DRIVER=cloudinary — from your Cloudinary dashboard.
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
