{
  "name": "casastruct-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Admin/API backend for CasaStruct — deployed separately from the Next.js frontend.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
