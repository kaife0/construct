{
  "name": "casastruct-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Admin/API backend for CasaStruct — deployed separately from the Next.js frontend.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed:admin": "tsx src/scripts/create-admin.ts",
    "seed:services": "tsx src/scripts/seed-services.ts",
    "seed:plans": "tsx src/scripts/seed-plans.ts",
    "seed:digital-products": "tsx src/scripts/seed-digital-products.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.5.0",
    "multer": "^2.2.0",
    "sharp": "^0.35.3",
    "slugify": "^1.6.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.14.0",
    "mongodb-memory-server": "^11.2.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
